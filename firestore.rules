rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Students can only read/write their own document
    match /students/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Classrooms are read-only for authenticated users
    match /classrooms/{classroomId} {
      allow read: if request.auth != null;
      allow write: if false; // backend only
    }

    // Attendance sessions are read-only for authenticated users
    match /attendance_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if false; // backend only
    }

    // Attendance records: student can read their own only
    match /attendance_records/{recordId} {
      allow read: if request.auth != null &&
                     resource.data.student_uid == request.auth.uid;
      allow write: if false; // backend only
    }

    // Rate limits and nonces: backend only (Admin SDK bypasses rules)
    match /rate_limits/{uid} {
      allow read, write: if false;
    }

    match /used_nonces/{nonce} {
      allow read, write: if false;
    }
  }
}
